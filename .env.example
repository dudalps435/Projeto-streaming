# Configuração de Integrações - Watchlist App

## 1. JustWatch API
# Obter em: https://www.justwatch.com/
# JUSTWATCH_API_KEY=sua_chave_aqui
# JUSTWATCH_PAIS=BR  # BR, US, GB, etc

## 2. Serviço de Email (Gmail recomendado)
# Gerar senha de app: https://myaccount.google.com/apppasswords
EMAIL_SERVICE=gmail
EMAIL_USER=seu_email@gmail.com
EMAIL_PASS=sua_senha_app_aqui
EMAIL_FROM="Watchlist <seu_email@gmail.com>"
EMAIL_REMETENTE_NOME="Watchlist"

## 3. Web Push Notifications
# Gerar chaves em: https://web-push-codelab.glitch.me/
VAPID_PUBLIC_KEY=sua_chave_publica_aqui
VAPID_PRIVATE_KEY=sua_chave_privada_aqui
VAPID_SUBJECT=mailto:seu_email@gmail.com

## 4. Telegram Bot
# Criar bot: https://t.me/BotFather
TELEGRAM_BOT_TOKEN=seu_token_aqui
TELEGRAM_CHAT_ID=seu_chat_id_aqui

## 5. Discord Webhook
# Criar webhook no servidor Discord
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/seu_webhook_aqui

## 6. TMDB API
TMDB_API_KEY=sua_chave_tmdb_aqui

## 7. Configurações da Aplicação
REACT_APP_API_URL=http://localhost:3001
NODE_ENV=development
PORT=3001

# Agendamento
ENVIAR_EMAIL_DIA=1  # 0=domingo, 1=segunda, etc
ENVIAR_EMAIL_HORA=9  # Hora em formato 24h
NOTIFICAR_NOVAS_PLATAFORMAS=true

# Países para JustWatch
PAISES_MONITORADOS=BR,US,GB,DE,FR

# Email para testes
TESTE_EMAIL=seu_email@gmail.com
